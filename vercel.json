{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    { "src": "public/index.php", "use": "@vercel/php" },
    { "src": "public/build/**", "use": "@vercel/static" },
    { "src": "public/images/**", "use": "@vercel/static" },
    { "src": "public/favicon.ico", "use": "@vercel/static" },
    { "src": "public/robots.txt", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/(.*)", "dest": "/public/index.php" }
  ]
}
